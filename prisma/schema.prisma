// Taskmatic — Prisma Schema (SQLite for MVP, easy swap to Postgres later)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  plan      String   @default("free")
  createdAt DateTime @default(now())
  runs      Run[]
}

model Run {
  id         String   @id @default(cuid())
  userId     String
  templateId String
  input      String
  output     String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}
